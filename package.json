{
  "name": "playwright-cucumber-typescript-ui",
  "version": "1.0.0",
  "private": true,
  "description": "A production-minded Playwright + TypeScript + Cucumber UI automation starter project",
  "scripts": {
    "clean": "rimraf dist reports test-results playwright-report",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"README.md\"",
    "test": "npm run typecheck && cucumber-js --config cucumber.cjs",
    "test:smoke": "cucumber-js --config cucumber.cjs --tags '@smoke'",
    "test:allure": "npm run test && npm run allure:generate",
    "allure:generate": "node -e \"process.env.JAVA_HOME=process.env.JAVA_HOME||'/opt/homebrew/Cellar/openjdk@17/17.0.19'; require('child_process').execSync('npx allure generate reports/allure-results -o reports/allure-report --clean', { stdio: 'inherit' })\"",
    "allure:open": "npx allure open reports/allure-report"
  },
  "dependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "@playwright/test": "^1.54.0",
    "dotenv": "^16.4.2",
    "playwright": "^1.54.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "allure-cucumberjs": "^3.10.2",
    "allure-commandline": "^2.43.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^4.2.5",
    "husky": "^8.0.3",
    "lint-staged": "^13.3.0",
    "prettier": "^2.8.8",
    "rimraf": "^6.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "npm run lint:fix",
      "npm run format",
      "git add"
    ]
  }
}